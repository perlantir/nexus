{
  "name": "@decigraph/core",
  "version": "0.1.0",
  "description": "Core engine: decision graph, context compiler, change propagator, distillery",
  "author": "Perlantir",
  "repository": {
    "type": "git",
    "url": "https://github.com/perlantir/decigraph"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./db/index.js": {
      "import": "./dist/db/index.js",
      "types": "./dist/db/index.d.ts"
    },
    "./db/pool.js": {
      "import": "./dist/db/pool.js",
      "types": "./dist/db/pool.d.ts"
    },
    "./db/parsers.js": {
      "import": "./dist/db/parsers.js",
      "types": "./dist/db/parsers.d.ts"
    },
    "./types.js": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./roles.js": {
      "import": "./dist/roles.js",
      "types": "./dist/roles.d.ts"
    },
    "./config/llm.js": {
      "import": "./dist/config/llm.js",
      "types": "./dist/config/llm.d.ts"
    },
    "./distillery/index.js": {
      "import": "./dist/distillery/index.js",
      "types": "./dist/distillery/index.d.ts"
    },
    "./distillery/extractor.js": {
      "import": "./dist/distillery/extractor.js",
      "types": "./dist/distillery/extractor.d.ts"
    },
    "./decision-graph/embeddings.js": {
      "import": "./dist/decision-graph/embeddings.js",
      "types": "./dist/decision-graph/embeddings.d.ts"
    },
    "./change-propagator/index.js": {
      "import": "./dist/change-propagator/index.js",
      "types": "./dist/change-propagator/index.d.ts"
    },
    "./contradiction-detector/index.js": {
      "import": "./dist/contradiction-detector/index.js",
      "types": "./dist/contradiction-detector/index.d.ts"
    },
    "./webhooks/index.js": {
      "import": "./dist/webhooks/index.js",
      "types": "./dist/webhooks/index.d.ts"
    },
    "./relevance-learner/index.js": {
      "import": "./dist/relevance-learner/index.js",
      "types": "./dist/relevance-learner/index.d.ts"
    },
    "./dependency-cascade/index.js": {
      "import": "./dist/dependency-cascade/index.js",
      "types": "./dist/dependency-cascade/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "better-sqlite3": "^12.8.0",
    "crypto-js": "^4.2.0",
    "openai": "^4.73.0",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
