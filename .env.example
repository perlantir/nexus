# Nexus Configuration
# Copy this file to .env and fill in your values

# Database (PostgreSQL 17 with pgvector)
DATABASE_URL=postgresql://nexus:nexus_dev@localhost:5432/nexus
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Embeddings Provider
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key

# Distillery LLM (for extraction pipeline)
DISTILLERY_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# Distillery model (configurable)
DISTILLERY_MODEL=claude-haiku-4-5-20251001
# Alternative: use OpenAI
# DISTILLERY_PROVIDER=openai
# DISTILLERY_MODEL=gpt-4o-mini

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# Auth
NEXUS_API_KEY=your-secret-key-for-hashing

# MCP Server
MCP_TRANSPORT=stdio

# Dashboard
VITE_API_URL=http://localhost:3100

# Rate Limiting
RATE_LIMIT_RPM=120

# Logging
LOG_LEVEL=info
