# DeciGraph Environment Configuration
# Copy to .env and fill in values

NODE_ENV=development

# Database (required)
DATABASE_URL=postgresql://nexus:nexus_dev@postgres:5432/nexus
DATABASE_SSL=false
# POSTGRES_PASSWORD=nexus_dev  # Only needed if changing default

# AI / Distillery (required for distillery features)
ANTHROPIC_API_KEY=sk-ant-your-key-here
DISTILLERY_PROVIDER=anthropic
DECIGRAPH_LLM_MODEL=claude-opus-4-6

# Security (recommended for production)
# DECIGRAPH_API_KEY=your-api-key-here

# Embeddings (optional — enables semantic similarity scoring)
# DECIGRAPH_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here

# CORS (production only — dev mode allows all origins)
# DECIGRAPH_CORS_ORIGINS=http://localhost:3200,https://yourdomain.com
