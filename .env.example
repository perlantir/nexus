# DeciGraph Environment Configuration
# Copy to .env and fill in values
# docker-compose reads this file automatically

# ── Docker / PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev
POSTGRES_DB=nexus
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_SSL=false

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3100

# ── Dashboard ───────────────────────────────────────────────────────
# Leave empty — nginx proxies /api/ to the server container.
# Never set to an absolute URL (http://...) in Docker.
VITE_API_URL=""

# ── AI / Distillery ─────────────────────────────────────────────────
# Required for distillery (decision extraction from conversations)
ANTHROPIC_API_KEY=sk-ant-your-key-here
DISTILLERY_PROVIDER=anthropic
DECIGRAPH_LLM_MODEL=claude-opus-4-6

# ── Embeddings (optional) ──────────────────────────────────────────
# Enables semantic similarity scoring in context compilation.
# Without this, the semantic_similarity signal is always 0.
# OPENAI_API_KEY=sk-your-key-here
# DECIGRAPH_EMBEDDING_PROVIDER=openai

# ── Security (recommended for production) ──────────────────────────
# When set, all API requests require: Authorization: Bearer <key>
# In development mode (NODE_ENV=development), auth is skipped.
# DECIGRAPH_API_KEY=your-api-key-here

# ── CORS (production only) ─────────────────────────────────────────
# Dev mode allows all origins. In production, list allowed origins:
# DECIGRAPH_CORS_ORIGINS=http://localhost:3200,https://yourdomain.com

# ── Auto-discovery (optional) ──────────────────────────────────────
# DECIGRAPH_OPENCLAW_PATH=/path/to/openclaw/workspace
# DECIGRAPH_WATCH_DIR=/path/to/watch

# ── Redis / Job Queue (optional) ─────────────────────────────────────────
# When set, ingestion uses BullMQ job queues for reliability + rate limiting.
# When not set, ingestion still works but processes inline (no queue).
# DECIGRAPH_REDIS_URL=redis://redis:6379

# ── Telegram Bot Ingestion (optional) ────────────────────────────────────
# Bot token from @BotFather
# DECIGRAPH_TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs to listen in (empty = all chats)
# DECIGRAPH_TELEGRAM_CHAT_IDS=
# Default project ID for ingested decisions
# DECIGRAPH_TELEGRAM_PROJECT_ID=
# Whether to reply with confirmation (default: true)
# DECIGRAPH_INGEST_REPLY_ENABLED=true

# ── OpenClaw Auto-Discovery (optional) ───────────────────────────────────
# Path to OpenClaw workspace (watches for .jsonl session files)
# DECIGRAPH_DEFAULT_PROJECT_ID=44c6cebd-b6ff-47b7-ad93-52925bf26eb0
# DECIGRAPH_OPENCLAW_PATH=/docker/openclaw-okny/data/.openclaw
# Alternative: any directory with .jsonl files
# DECIGRAPH_WATCH_DIR=
# Default project ID (falls back to DECIGRAPH_TELEGRAM_PROJECT_ID)
# DECIGRAPH_OPENCLAW_PROJECT_ID=

# ── GitHub PR Integration (optional) ─────────────────────────────────────
# HMAC secret for webhook signature verification
# DECIGRAPH_GITHUB_WEBHOOK_SECRET=
# Default project for PR decisions (falls back to DECIGRAPH_DEFAULT_PROJECT_ID)
# DECIGRAPH_GITHUB_PROJECT_ID=

# ── Discord Bot (optional) ───────────────────────────────────────────────
# Bot token from Discord Developer Portal
# DECIGRAPH_DISCORD_BOT_TOKEN=
# Default project ID for ingested decisions
# DECIGRAPH_DISCORD_PROJECT_ID=
# Comma-separated guild IDs to listen in (empty = all guilds)
# DECIGRAPH_DISCORD_GUILD_IDS=
# Comma-separated channel IDs to listen in (empty = all channels)
# DECIGRAPH_DISCORD_CHANNEL_IDS=

# ── Slack Integration (optional) ─────────────────────────────────────────
# Slack signing secret from app settings (for webhook verification)
# DECIGRAPH_SLACK_SIGNING_SECRET=
# Default project ID for ingested decisions
# DECIGRAPH_SLACK_PROJECT_ID=
# Comma-separated channel IDs to listen in (empty = all channels)
# DECIGRAPH_SLACK_CHANNEL_IDS=
