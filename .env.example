# DeciGraph Configuration

# Database
DATABASE_URL=postgresql://decigraph:decigraph_dev@localhost:5432/decigraph
DATABASE_SSL=false

# LLM (for distillery + contradiction detection)
# Supports: Anthropic, OpenAI, OpenRouter
ANTHROPIC_API_KEY=sk-ant-...
DECIGRAPH_LLM_MODEL=claude-opus-4-6
# LLM_TIMEOUT_MS=120000

# Embeddings (for semantic similarity in context compilation)
# Without this, context compilation uses zero-vectors (no semantic signal)
OPENAI_API_KEY=sk-...
# Or use a custom endpoint:
# DECIGRAPH_EMBEDDINGS_URL=http://localhost:11434/api/embeddings
# DECIGRAPH_EMBEDDINGS_MODEL=nomic-embed-text

# API key (leave empty for development — auth is skipped in dev mode)
DECIGRAPH_API_KEY=

# Server
NODE_ENV=development
PORT=3100

# CORS (production only — dev mode allows all origins)
# DECIGRAPH_CORS_ORIGINS=http://localhost:3200,https://yourdomain.com

# Auto-discovery
# DECIGRAPH_OPENCLAW_PATH=/path/to/openclaw/workspace
# DECIGRAPH_WATCH_DIR=/path/to/watch
