# Nexus Configuration
# Copy this file to .env and fill in your values

# Database (PostgreSQL 17 with pgvector)
DATABASE_URL=postgresql://nexus:nexus_dev@localhost:5432/nexus
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Set to true only if your PostgreSQL server requires SSL
# (e.g., managed cloud databases like Supabase, RDS, Neon)
# Leave unset or false for local/docker PostgreSQL
# DATABASE_SSL=true

# =============================================
# LLM PROVIDER (optional — Nexus works without this)
# =============================================
# Nexus uses LLM calls for two optional features:
#   - Embeddings: improves search accuracy (semantic similarity)
#   - Distillery: auto-extracts decisions from conversation text
#
# Without any keys, Nexus still works — search uses text matching
# and decisions are recorded manually by agents.
#
# QUICK SETUP — pick one:
#
# Option A: OpenRouter (one key, all features, 200+ models)
# OPENROUTER_API_KEY=sk-or-your-key-here
#
# Option B: Direct provider keys
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
#
# Option C: No keys — skip this section entirely
#
# ADVANCED — override model or endpoint for either feature:
# NEXUS_EMBEDDINGS_URL=http://localhost:11434/v1
# NEXUS_EMBEDDINGS_KEY=ollama
# NEXUS_EMBEDDINGS_MODEL=nomic-embed-text
# NEXUS_LLM_URL=https://api.groq.com/openai/v1
# NEXUS_LLM_KEY=gsk_your-groq-key
# NEXUS_LLM_MODEL=llama-3.3-70b-versatile

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# Auth
NEXUS_API_KEY=your-secret-key-for-hashing

# MCP Server
MCP_TRANSPORT=stdio

# Dashboard
VITE_API_URL=http://localhost:3100

# Rate Limiting
RATE_LIMIT_RPM=120

# =============================================
# AUTO-DISCOVERY (optional)
# =============================================
# OpenClaw workspace path — enables automatic conversation import
# NEXUS_OPENCLAW_PATH=/data/.openclaw
# Default agent name for the base OpenClaw workspace (no suffix)
# NEXUS_OPENCLAW_DEFAULT_AGENT=maks

# Generic directory watcher
# NEXUS_WATCH_DIR=/path/to/agent/logs
# NEXUS_WATCH_PATTERN=*.md

# Webhook secret (defaults to NEXUS_API_KEY if not set)
# NEXUS_WEBHOOK_SECRET=

# Poll interval in milliseconds (default: 30000)
# NEXUS_DISCOVERY_INTERVAL=30000

# Logging
LOG_LEVEL=info
